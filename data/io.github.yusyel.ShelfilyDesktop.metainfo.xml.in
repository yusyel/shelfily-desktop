<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.yusyel.ShelfilyDesktop</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>Shelfily Desktop</name>
  <summary>Modern Audiobookshelf desktop client</summary>
  <icon type="stock">io.github.yusyel.ShelfilyDesktop</icon>
  <description>
    <p>
      Shelfily Desktop is a GTK4/libadwaita client for Audiobookshelf.
      It provides login, library browsing, item details, and audio playback in a native Linux desktop interface.
    </p>
  </description>

  <developer id="io.github.yusyel">
    <name>yusyel</name>
  </developer>

  <url type="homepage">https://github.com/yusyel/shelfily-desktop</url>
  <url type="vcs-browser">https://github.com/yusyel/shelfily-desktop</url>
  <url type="bugtracker">https://github.com/yusyel/shelfily-desktop/issues</url>
  <categories>
    <category>AudioVideo</category>
    <category>Network</category>
  </categories>
  <screenshots>
    <screenshot type="default">
      <caption>Shelfily Desktop main library view</caption>
      <image type="source">https://raw.githubusercontent.com/yusyel/shelfily-desktop/main/sc.png</image>
    </screenshot>
  </screenshots>

  <translation type="gettext">shelfily-desktop</translation>
  <launchable type="desktop-id">io.github.yusyel.ShelfilyDesktop.desktop</launchable>
  <content_rating type="oars-1.1"/>

  <releases>
    <release version="2.1.0" date="2026-05-28">
      <description>
        <p>UI polish and quality-of-life improvements.</p>
        <ul>
          <li>Rounded cover artwork throughout the app</li>
          <li>Progress badge on book covers and proper empty/no-results states</li>
          <li>Keyboard shortcuts (Space, arrows, Ctrl+B, Ctrl+F) with a shortcuts window</li>
          <li>Search moved to a search bar and now also filters the Bookmarks tab</li>
          <li>"30" labels on the skip buttons and chapter markers on the seek bar</li>
          <li>Skeleton loading placeholders and smoother, breakpoint-based resizing</li>
          <li>Mini-player cover keeps the cover aspect ratio</li>
        </ul>
      </description>
    </release>
    <release version="2.0.0" date="2026-05-27">
      <description>
        <p>Major update with a full-screen Now Playing experience and desktop integration.</p>
        <ul>
          <li>Now Playing screen with cover-derived ambient background, 30s skips, speed control, sleep timer, bookmarks, and a chapter list with chapter-relative progress</li>
          <li>MPRIS media controls: media keys, GNOME panel and lock-screen controls with cover art</li>
          <li>Bookmarks with editable notes and a dedicated Bookmarks tab grouped by book</li>
          <li>Dark mode selectable from Preferences</li>
          <li>Markdown/HTML book descriptions, author book listings, and a Recently Played sort</li>
          <li>Smoother window resizing and several playback/seek fixes</li>
        </ul>
      </description>
    </release>
    <release version="0.1.19" date="2026-03-23"/>
  </releases>
</component>
